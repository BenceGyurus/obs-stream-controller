# YouTube Data API v3 Key (for read-only operations)
YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY_HERE"

# Your YouTube Channel ID
YOUTUBE_CHANNEL_ID="YOUR_YOUTUBE_CHANNEL_ID_HERE"

# YouTube OAuth2 Credentials (for broadcast management)
# Download client_secret.json from Google Cloud Console and place it in the project root
# Or provide the path to the credentials file
YOUTUBE_CLIENT_SECRET_FILE="client_secret.json"

# YouTube Broadcast ID (optional - for manual broadcast selection)
# Leave empty to auto-detect the active broadcast (LIVE > READY > TESTING priority)
# Set this if you want to use a specific broadcast or if auto-detection fails
# Example: YOUTUBE_BROADCAST_ID="abc123xyz456"
YOUTUBE_BROADCAST_ID=""

# YouTube Broadcast Reset (optional - enables/disables broadcast reset feature)
# WARNING: Broadcast reset changes privacy from "public" to "unlisted" during transitions!
# Set to "true" to enable broadcast reset (helps with OBS reconnection)
# Set to "false" to disable (keeps privacy settings but may need manual stream key re-entry)
# Default: false (disabled for privacy preservation)
YOUTUBE_BROADCAST_RESET="false"

# Force YouTube broadcast to be "public" after a reset (optional)
# If set to "true", the stream will always be public after it restarts, 
# even if it was originally unlisted or private.
# Default: false (preserves original privacy)
YOUTUBE_FORCE_PUBLIC_ON_RESET="false"

# OAuth Headless Mode (for Synology NAS or servers without browser)
# Set to "true" to use console-based authentication
# This will display a URL and code that you can enter on any device with a browser
OAUTH_HEADLESS="false"

# OBS WebSocket Server Settings
OBS_WEBSOCKET_HOST="host.docker.internal"
OBS_WEBSOCKET_PORT="4455"
OBS_WEBSOCKET_PASSWORD="YOUR_OBS_WEBSOCKET_PASSWORD_HERE"

# Telegram Notifications (optional)
# Set to "true" to enable Telegram alerts
TELEGRAM_ENABLED="false"
# Your Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=""
# Your Telegram Chat ID from @userinfobot or similar
TELEGRAM_CHAT_ID=""
# Notify when YouTube stream goes offline (default: true)
TELEGRAM_NOTIFY_ON_YOUTUBE_OFFLINE="true"
# Notify when OBS stream goes offline (default: true)
TELEGRAM_NOTIFY_ON_OBS_OFFLINE="true"
